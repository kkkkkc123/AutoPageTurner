<Window x:Class="AutoPageTurner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoPageTurner"
        mc:Ignorable="d"
        Title="AutoPageTurner"
        Height="690"
        Width="860"
        MinHeight="560"
        MinWidth="720"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2933" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1F2933" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionPanel" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="AutoPageTurner"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="后台自动翻页工具"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#EAF1FF"
                    BorderBrush="#BFD0FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="状态"
                               Style="{StaticResource MutedText}"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Status}"
                               FontWeight="SemiBold"
                               Foreground="#1D4ED8" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   Text="目标窗口"
                                   Style="{StaticResource SectionTitle}" />

                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding Windows}"
                                  SelectedItem="{Binding SelectedWindow}"
                                  IsEnabled="{Binding IsEditingEnabled}"
                                  Margin="0,0,12,0" />

                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Content="刷新窗口"
                                IsEnabled="{Binding IsEditingEnabled}"
                                Command="{Binding RefreshCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="3"
                                       Text="翻页设置"
                                       Style="{StaticResource SectionTitle}" />

                            <CheckBox Grid.Row="1"
                                      Grid.ColumnSpan="3"
                                      Content="随机翻页间隔"
                                      IsChecked="{Binding UseRandomInterval}"
                                      IsEnabled="{Binding IsEditingEnabled}"
                                      Margin="0,0,0,14" />

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="固定间隔(ms)"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsFixedIntervalEnabled}"
                                         Text="{Binding Interval, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="翻页动作"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <ComboBox ItemsSource="{Binding PageActions}"
                                          SelectedItem="{Binding PageAction}"
                                          IsEnabled="{Binding IsEditingEnabled}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,14,0,0">
                                <TextBlock Text="最小间隔(ms)"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsRandomIntervalEnabled}"
                                         Text="{Binding MinInterval, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Grid.Column="2"
                                        Margin="0,14,0,0">
                                <TextBlock Text="最大间隔(ms)"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsRandomIntervalEnabled}"
                                         Text="{Binding MaxInterval, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="3"
                                       Text="自动点击"
                                       Style="{StaticResource SectionTitle}" />

                            <CheckBox Grid.Row="1"
                                      Grid.ColumnSpan="3"
                                      Content="启用自动点击"
                                      IsChecked="{Binding EnableAutoClick}"
                                      IsEnabled="{Binding IsEditingEnabled}"
                                      Margin="0,0,0,14" />

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="X 坐标"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsClickSettingsEnabled}"
                                         Text="{Binding ClickX, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Y 坐标"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsClickSettingsEnabled}"
                                         Text="{Binding ClickY, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Grid.ColumnSpan="3"
                                        Margin="0,14,0,0">
                                <TextBlock Text="点击后等待(ms)"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="拾取坐标"
                                            Command="{Binding PickPointCommand}"
                                            Margin="12,0,0,0" />
                                    <TextBox IsEnabled="{Binding IsClickSettingsEnabled}"
                                             Text="{Binding ClickDelay, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                                </DockPanel>
                            </StackPanel>

                            <CheckBox Grid.Row="4"
                                      Grid.Column="0"
                                      Content="启用点击漂移"
                                      IsChecked="{Binding EnableClickDrift}"
                                      IsEnabled="{Binding IsClickSettingsEnabled}"
                                      VerticalAlignment="Bottom"
                                      Margin="0,14,0,8" />

                            <StackPanel Grid.Row="4"
                                        Grid.Column="2"
                                        Margin="0,14,0,0">
                                <TextBlock Text="漂移半径(px)"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,6" />
                                <TextBox IsEnabled="{Binding IsDriftSettingsEnabled}"
                                         Text="{Binding ClickDriftRadius, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,18,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CountdownText}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ConfigFilePath}"
                               Style="{StaticResource MutedText}"
                               Margin="0,4,12,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="恢复默认"
                        Command="{Binding ResetCommand}"
                        Margin="8,0,0,0" />

                <Button Grid.Column="2"
                        Content="测试点击"
                        Command="{Binding TestClickCommand}"
                        Margin="8,0,0,0" />

                <Button Grid.Column="3"
                        Content="测试翻页"
                        Command="{Binding TestPageCommand}"
                        Margin="8,0,0,0" />

                <Button Grid.Column="4"
                        Content="停止"
                        Command="{Binding StopCommand}"
                        Margin="8,0,0,0" />

                <Button Grid.Column="5"
                        Content="开始"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartCommand}"
                        Margin="8,0,0,0" />

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="6"
                           Text="作者：kkkkkc123"
                           Style="{StaticResource MutedText}"
                           Margin="0,10,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>
